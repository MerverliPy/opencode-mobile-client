{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "tools": {
    "playwright_*": false
  },
  "agent": {
    "validator": {
      "tools": {
        "playwright_*": true
      },
      "permission": {
        "bash": {
          "npm run preview:host*": "allow",
          "npm run validate:local*": "allow"
        }
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "instructions": [
    "AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".next/**",
      "coverage/**"
    ]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "webkit",
        "--headless",
        "--caps",
        "network",
        "--output-dir",
        "playwright-artifacts"
      ],
      "enabled": true
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdnsDomain": "opencode-mobile.local"
  }
}
